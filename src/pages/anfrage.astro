---
import Layout from '../layouts/Layout.astro';

const wa = 'https://wa.me/4915566111551?text=Hallo%2C%20ich%20suche%20folgendes%20Teil%3A%20';
---

<Layout
  title="Anfrage | B&A Autoteile Dortmund - Foto schicken, Preis bekommen"
  description="Autoteile anfragen in Dortmund: WhatsApp-Foto schicken, Preis und Verfügbarkeit in < 30 Min erhalten. Oder Formular ausfüllen. 5.0★ Reputation."
>

  <section class="bg-black text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img src="https://images.pexels.com/photos/3807277/pexels-photo-3807277.jpeg?auto=compress&cs=tinysrgb&w=1600"
           alt="" class="w-full h-full object-cover"/>
    </div>
    <div class="container-x relative py-16 md:py-24">
      <span class="eyebrow">Teile-Anfrage</span>
      <h1 class="mt-3 text-4xl md:text-6xl font-black text-white text-shadow-strong">
        Teil gesucht?<br/><span class="red-accent">In 2 Minuten zur Antwort.</span>
      </h1>
      <p class="mt-5 text-lg text-gray-200 max-w-2xl">
        Drei Wege - du wählst, was am schnellsten geht. WhatsApp ist bei uns die Nr. 1.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="grid lg:grid-cols-3 gap-6">

        <a href={wa} target="_blank" rel="noopener" class="card relative overflow-hidden hover:border-[#25D366] lg:scale-105">
          <span class="absolute top-4 right-4 px-3 py-1 bg-[#25D366] text-white text-xs font-black uppercase tracking-widest rounded">Bevorzugt</span>
          <div class="text-5xl mb-3">📱</div>
          <h2 class="text-2xl font-black">WhatsApp-Anfrage</h2>
          <p class="text-gray-700 mt-3">
            Foto vom Teil oder Teile-Nummer schicken. Antwort meist <strong class="text-black">unter 30 Min</strong> während Öffnungszeiten.
          </p>
          <ul class="mt-4 space-y-1.5 text-sm text-gray-800">
            <li class="flex gap-2"><span class="text-green-600 font-black">✓</span> Schnellste Variante</li>
            <li class="flex gap-2"><span class="text-green-600 font-black">✓</span> Foto direkt vom Handy</li>
            <li class="flex gap-2"><span class="text-green-600 font-black">✓</span> Direkter Draht zu uns</li>
          </ul>
          <span class="btn btn-whatsapp btn-lg w-full mt-6">WhatsApp öffnen</span>
        </a>

        <a href="tel:+4915566111551" class="card hover:border-red-600">
          <div class="text-5xl mb-3">📞</div>
          <h2 class="text-2xl font-black">Telefon</h2>
          <p class="text-gray-700 mt-3">
            Direkter Anruf zur persönlichen Beratung. Beste Wahl bei komplexen Fragen.
          </p>
          <ul class="mt-4 space-y-1.5 text-sm text-gray-800">
            <li class="flex gap-2"><span class="text-red-600 font-black">✓</span> Persönliche Beratung</li>
            <li class="flex gap-2"><span class="text-red-600 font-black">✓</span> Komplexe Anfragen klären</li>
            <li class="flex gap-2"><span class="text-red-600 font-black">✓</span> Während Öffnungszeiten</li>
          </ul>
          <span class="btn btn-red btn-lg w-full mt-6">+49 15566 111551</span>
        </a>

        <a href="#formular" class="card hover:border-black">
          <div class="text-5xl mb-3">📋</div>
          <h2 class="text-2xl font-black">Formular</h2>
          <p class="text-gray-700 mt-3">
            Klassisch per Formular. Wir melden uns am gleichen Tag zurück.
          </p>
          <ul class="mt-4 space-y-1.5 text-sm text-gray-800">
            <li class="flex gap-2"><span class="font-black">✓</span> Außerhalb Öffnungszeiten</li>
            <li class="flex gap-2"><span class="font-black">✓</span> Strukturierte Anfrage</li>
            <li class="flex gap-2"><span class="font-black">✓</span> Antwort gleichen Tag</li>
          </ul>
          <span class="btn btn-outline btn-lg w-full mt-6">Zum Formular ↓</span>
        </a>

      </div>

      <div class="mt-12 text-center">
        <div class="inline-flex items-center gap-3 px-5 py-3 bg-gray-100 border border-gray-300 rounded-full">
          <span class="text-red-600 font-bold">★★★★★</span>
          <span class="text-sm font-bold">5.0 aus 22 Bewertungen - unsere Kunden vertrauen uns.</span>
        </div>
      </div>
    </div>
  </section>

  <section id="formular" class="section gray-section">
    <div class="container-x">
      <div class="max-w-2xl mx-auto">
        <span class="eyebrow">Teile-Anfrage-Formular</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-black">Sag uns, was du brauchst.</h2>
        <span class="divider-red mt-5"></span>

        <form action="https://formspree.io/f/your-form-id" method="POST" class="mt-8 bg-white rounded-2xl p-6 md:p-8 border border-gray-300 space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="marke" class="block text-sm font-bold mb-1.5">Marke *</label>
              <input id="marke" name="marke" required type="text" placeholder="z.B. Audi" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
            <div>
              <label for="modell" class="block text-sm font-bold mb-1.5">Modell *</label>
              <input id="modell" name="modell" required type="text" placeholder="z.B. A4 Avant" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="baujahr" class="block text-sm font-bold mb-1.5">Baujahr</label>
              <input id="baujahr" name="baujahr" type="text" placeholder="z.B. 2018" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
            <div>
              <label for="teilenummer" class="block text-sm font-bold mb-1.5">Teile-Nummer (falls bekannt)</label>
              <input id="teilenummer" name="teilenummer" type="text" placeholder="OEM-Nummer" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
          </div>

          <div>
            <label for="gesucht" class="block text-sm font-bold mb-1.5">Was wird gesucht? *</label>
            <textarea id="gesucht" name="gesucht" required rows="4" placeholder="z.B. Bremsscheiben + Beläge vorn, am liebsten Bosch oder gleichwertig" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"></textarea>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-bold mb-1.5">Name *</label>
              <input id="name" name="name" required type="text" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
            <div>
              <label for="kontakt" class="block text-sm font-bold mb-1.5">Telefon / E-Mail *</label>
              <input id="kontakt" name="kontakt" required type="text" placeholder="0155 ... oder name@..." class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
          </div>

          <div class="flex items-start gap-2 text-sm">
            <input id="dsgvo" name="dsgvo" type="checkbox" required class="mt-1"/>
            <label for="dsgvo" class="text-gray-700">
              Ich habe die <a href="/datenschutz" class="underline font-bold">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung dieser Anfrage zu.
            </label>
          </div>

          <button type="submit" class="btn btn-red btn-lg w-full">Anfrage senden</button>

          <p class="text-xs text-gray-600 text-center">
            Tipp: Schneller geht's per <a href={wa} target="_blank" rel="noopener" class="underline font-bold">WhatsApp</a> mit Foto.
          </p>
        </form>
      </div>
    </div>
  </section>

</Layout>
