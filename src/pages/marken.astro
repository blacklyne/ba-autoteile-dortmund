---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const wa = 'https://wa.me/4915566111551?text=Hallo%2C%20ich%20suche%20folgendes%20Teil%3A%20';

const gruppen = [
  {
    region: 'Deutschland',
    marken: ['Audi', 'BMW', 'Mercedes-Benz', 'VW', 'Opel', 'Porsche', 'Smart', 'Mini'],
  },
  {
    region: 'Japan',
    marken: ['Toyota', 'Honda', 'Mazda', 'Nissan', 'Mitsubishi', 'Suzuki', 'Subaru', 'Lexus', 'Infiniti'],
  },
  {
    region: 'Korea',
    marken: ['Kia', 'Hyundai', 'SsangYong'],
  },
  {
    region: 'Frankreich',
    marken: ['Renault', 'Peugeot', 'Citroën', 'DS', 'Dacia'],
  },
  {
    region: 'Italien',
    marken: ['Fiat', 'Alfa Romeo', 'Lancia', 'Maserati'],
  },
  {
    region: 'Spanien',
    marken: ['Seat'],
  },
  {
    region: 'Tschechien',
    marken: ['Skoda'],
  },
  {
    region: 'USA',
    marken: ['Ford', 'Jeep', 'Chrysler', 'Dodge', 'Tesla'],
  },
  {
    region: 'Schweden',
    marken: ['Volvo', 'Saab'],
  },
];
---

<Layout
  title="Marken | B&A Autoteile Dortmund - Audi, BMW, VW, Mercedes & alle anderen"
  description="Autoteile für alle Marken in Dortmund. Audi, BMW, Mercedes, VW, Opel, Toyota, Honda, Renault und viele mehr. Auch Exoten und Oldtimer."
>

  <section class="bg-black text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img src="/images/filter-regal.jpg"
           alt="" class="w-full h-full object-cover"/>
    </div>
    <div class="container-x relative py-16 md:py-24">
      <span class="eyebrow">Marken-Übersicht</span>
      <h1 class="mt-3 text-4xl md:text-6xl font-black text-white text-shadow-strong">
        Wir liefern für<br/><span class="red-accent">jedes Auto.</span>
      </h1>
      <p class="mt-5 text-lg text-gray-200 max-w-2xl">
        Egal ob deutscher Klassiker, japanischer Allrounder oder italienischer Exot - wir haben oder besorgen das passende Teil.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {gruppen.map((g) => (
          <div class="card">
            <div class="flex items-center gap-3 mb-4 pb-4 border-b border-gray-200">
              <div class="w-10 h-10 rounded-lg bg-black text-white flex items-center justify-center flex-shrink-0">
                <Icon name="car" size={20}/>
              </div>
              <h2 class="text-xl font-black">{g.region}</h2>
            </div>
            <div class="flex flex-wrap gap-2">
              {g.marken.map((m) => (
                <span class="px-3 py-1.5 bg-gray-100 text-gray-900 rounded text-sm font-bold">{m}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-14 bg-black text-white rounded-2xl p-8 md:p-14 text-center relative overflow-hidden">
        <div class="absolute -right-20 -bottom-20 w-80 h-80 rounded-full bg-red-600/20 blur-3xl pointer-events-none"></div>
        <div class="relative">
          <span class="text-xs uppercase tracking-widest font-black red-accent">Auch Exoten + Oldtimer</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-black text-white">Deine Marke nicht dabei? <span class="red-accent">Frag uns.</span></h2>
          <p class="mt-4 text-gray-300 max-w-xl mx-auto">
            Wir beschaffen Teile für nahezu alle Marken weltweit - auch für Oldtimer und seltene Modelle. Schick einfach Foto oder Teile-Nummer.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href={wa} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
              <Icon name="whatsapp" size={18}/> WhatsApp anfragen
            </a>
            <a href="tel:+4915566111551" class="btn btn-outline-white btn-lg">
              <Icon name="phone" size={18}/> Anrufen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section gray-section">
    <div class="container-x">
      <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="eyebrow">Original oder gleichwertig</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-black">OEM oder Aftermarket - <span class="red-accent">du entscheidest.</span></h2>
          <span class="divider-red mt-5"></span>
          <p class="mt-6 text-gray-700 text-lg leading-relaxed">
            Wir führen sowohl Original-Teile (OEM) als auch hochwertige Alternativen von Premium-Herstellern. Was passt, hängt von deinem Budget und Anspruch ab - wir beraten dich ehrlich.
          </p>
          <ul class="mt-6 space-y-3 text-gray-800">
            <li class="flex items-start gap-3"><Icon name="check" size={18} class="red-accent flex-shrink-0 mt-1"/> Bosch, Continental, Mahle, Sachs, ATE, TRW</li>
            <li class="flex items-start gap-3"><Icon name="check" size={18} class="red-accent flex-shrink-0 mt-1"/> Original-Hersteller-Teile</li>
            <li class="flex items-start gap-3"><Icon name="check" size={18} class="red-accent flex-shrink-0 mt-1"/> Geprüfte Gebrauchtteile auf Anfrage</li>
          </ul>
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden shadow-xl">
          <img src="/images/filter-regal.jpg"
               alt="Premium-Marken-Teile von Bosch, Mann, Mahle, Meyle" class="w-full h-full object-cover" loading="lazy"/>
        </div>
      </div>
    </div>
  </section>

</Layout>
