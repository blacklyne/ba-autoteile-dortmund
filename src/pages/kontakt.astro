---
import Layout from '../layouts/Layout.astro';

const wa = 'https://wa.me/4915566111551?text=Hallo%2C%20ich%20suche%20folgendes%20Teil%3A%20';
---

<Layout
  title="Kontakt | B&A Autoteile Dortmund - WhatsApp, Telefon, Adresse"
  description="Kontakt zu B&A Autoteile in Dortmund-Mitte. WhatsApp: 0155 66 111551. Bleichmärsch 24, 44145 Dortmund. Mo-Fr 09-17:30, Sa 09-14."
>

  <section class="bg-black text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img src="https://images.pexels.com/photos/4489734/pexels-photo-4489734.jpeg?auto=compress&cs=tinysrgb&w=1600"
           alt="" class="w-full h-full object-cover"/>
    </div>
    <div class="container-x relative py-16 md:py-24">
      <span class="eyebrow">Kontakt</span>
      <h1 class="mt-3 text-4xl md:text-6xl font-black text-white text-shadow-strong">
        So erreichst du uns.
      </h1>
      <p class="mt-5 text-lg text-gray-200 max-w-2xl">
        WhatsApp ist am schnellsten. Telefon für persönliche Beratung. E-Mail für alles andere.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="grid lg:grid-cols-3 gap-5">
        <a href={wa} target="_blank" rel="noopener" class="card hover:border-[#25D366] relative">
          <span class="absolute top-4 right-4 px-3 py-1 bg-[#25D366] text-white text-xs font-black uppercase tracking-widest rounded">Hauptkanal</span>
          <div class="text-5xl mb-3">📱</div>
          <h2 class="text-xl font-black">WhatsApp</h2>
          <p class="text-gray-700 mt-2">+49 15566 111551</p>
          <p class="text-sm text-gray-600 mt-2">Foto schicken - Preis bekommen. Antwort meist &lt; 30 Min.</p>
          <span class="btn btn-whatsapp w-full mt-5">Chat öffnen</span>
        </a>

        <a href="tel:+4915566111551" class="card hover:border-red-600">
          <div class="text-5xl mb-3">📞</div>
          <h2 class="text-xl font-black">Telefon</h2>
          <p class="text-gray-700 mt-2">+49 15566 111551</p>
          <p class="text-sm text-gray-600 mt-2">Persönliche Beratung während Öffnungszeiten.</p>
          <span class="btn btn-red w-full mt-5">Jetzt anrufen</span>
        </a>

        <a href="mailto:info@ba-autoteile.de" class="card hover:border-black">
          <div class="text-5xl mb-3">✉</div>
          <h2 class="text-xl font-black">E-Mail</h2>
          <p class="text-gray-700 mt-2">info@ba-autoteile.de</p>
          <p class="text-sm text-gray-600 mt-2">Für alles, was nicht eilig ist. Antwort am gleichen Tag.</p>
          <span class="btn btn-outline w-full mt-5">E-Mail schreiben</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section gray-section">
    <div class="container-x">
      <div class="grid lg:grid-cols-2 gap-10">
        <div>
          <span class="eyebrow">Standort</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-black">Bleichmärsch 24<br/><span class="red-accent">Dortmund-Mitte.</span></h2>
          <span class="divider-red mt-5"></span>

          <div class="mt-8 space-y-6">
            <div>
              <div class="text-xs uppercase tracking-widest font-bold text-gray-600">Anschrift</div>
              <div class="text-lg font-bold mt-1">
                B&amp;A Autoteile<br/>
                Bleichmärsch 24<br/>
                44145 Dortmund-Mitte
              </div>
            </div>

            <div>
              <div class="text-xs uppercase tracking-widest font-bold text-gray-600">Öffnungszeiten</div>
              <div class="mt-2 space-y-1">
                <div class="flex justify-between max-w-xs"><span class="font-bold">Mo - Fr</span><span>09:00 - 17:30</span></div>
                <div class="flex justify-between max-w-xs"><span class="font-bold">Samstag</span><span class="red-accent font-bold">09:00 - 14:00</span></div>
                <div class="flex justify-between max-w-xs"><span class="font-bold">Sonntag</span><span class="text-gray-600">geschlossen</span></div>
              </div>
            </div>

            <div>
              <div class="text-xs uppercase tracking-widest font-bold text-gray-600">Zahlung</div>
              <div class="mt-1 text-gray-800">Bar · EC-Karte · Überweisung · PayPal</div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-xl border border-gray-300 aspect-square lg:aspect-auto lg:min-h-[500px]">
          <iframe
            src="https://maps.google.com/maps?q=Bleichm%C3%A4rsch%2024%2C%2044145%20Dortmund&t=&z=15&ie=UTF8&iwloc=&output=embed"
            width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="B&A Autoteile auf Google Maps"></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="max-w-2xl mx-auto">
        <span class="eyebrow">Nachricht senden</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-black">Schreib uns.</h2>
        <span class="divider-red mt-5"></span>

        <form action="https://formspree.io/f/your-form-id" method="POST" class="mt-8 space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="kname" class="block text-sm font-bold mb-1.5">Name *</label>
              <input id="kname" name="name" required type="text" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
            <div>
              <label for="kemail" class="block text-sm font-bold mb-1.5">E-Mail / Telefon *</label>
              <input id="kemail" name="kontakt" required type="text" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"/>
            </div>
          </div>
          <div>
            <label for="knachricht" class="block text-sm font-bold mb-1.5">Nachricht *</label>
            <textarea id="knachricht" name="nachricht" required rows="5" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:border-black focus:ring-2 focus:ring-black/10 outline-none"></textarea>
          </div>
          <div class="flex items-start gap-2 text-sm">
            <input id="kdsgvo" name="dsgvo" type="checkbox" required class="mt-1"/>
            <label for="kdsgvo" class="text-gray-700">
              Ich habe die <a href="/datenschutz" class="underline font-bold">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu.
            </label>
          </div>
          <button type="submit" class="btn btn-red btn-lg w-full">Nachricht senden</button>
          <p class="text-xs text-gray-600 text-center">
            Schneller geht's per <a href={wa} target="_blank" rel="noopener" class="underline font-bold">WhatsApp</a>.
          </p>
        </form>
      </div>
    </div>
  </section>

</Layout>
