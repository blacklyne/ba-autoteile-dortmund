---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const wa = 'https://wa.me/4915566111551?text=Hallo%2C%20ich%20suche%20folgendes%20Teil%3A%20';
---

<Layout
  title="Kontakt | B&A Autoteile Dortmund - WhatsApp, Telefon, Adresse"
  description="Kontakt zu B&A Autoteile in Dortmund-Mitte. WhatsApp: 0155 66 111551. Bleichmärsch 24, 44145 Dortmund. Mo-Fr 09-17:30, Sa 09-14."
>

  <section class="bg-black text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img src="/images/bremsenreiniger.jpg"
           alt="" class="w-full h-full object-cover"/>
    </div>
    <div class="container-x relative py-16 md:py-24">
      <span class="eyebrow">Kontakt</span>
      <h1 class="mt-3 text-4xl md:text-6xl font-black text-white text-shadow-strong">
        So erreichst du uns.
      </h1>
      <p class="mt-5 text-lg text-gray-200 max-w-2xl">
        WhatsApp ist am schnellsten. Telefon für persönliche Beratung. E-Mail für alles andere.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="grid lg:grid-cols-3 gap-6">

        <a href={wa} target="_blank" rel="noopener"
           class="group relative overflow-hidden rounded-2xl bg-[#25D366] text-white p-8 shadow-xl hover:shadow-2xl transition-all hover:-translate-y-1">
          <div class="absolute -right-12 -top-12 w-48 h-48 rounded-full bg-white/10 blur-2xl"></div>
          <div class="relative">
            <span class="inline-block px-3 py-1 bg-white text-[#25D366] text-xs font-black uppercase tracking-widest rounded">Hauptkanal</span>
            <div class="mt-6 w-14 h-14 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center">
              <Icon name="whatsapp" size={32}/>
            </div>
            <h2 class="mt-6 text-2xl font-black">WhatsApp</h2>
            <p class="mt-3 text-white/95 text-lg font-bold">+49 15566 111551</p>
            <p class="mt-2 text-white/80 text-sm">Foto schicken - Preis bekommen. Antwort meist unter 30 Min.</p>
            <div class="mt-6 inline-flex items-center gap-2 font-bold uppercase tracking-wide text-sm group-hover:gap-3 transition-all">
              Chat öffnen <Icon name="arrow" size={16}/>
            </div>
          </div>
        </a>

        <a href="tel:+4915566111551"
           class="group relative overflow-hidden rounded-2xl bg-black text-white p-8 shadow-xl hover:shadow-2xl transition-all hover:-translate-y-1">
          <div class="absolute -right-12 -top-12 w-48 h-48 rounded-full bg-red-600/30 blur-2xl"></div>
          <div class="relative">
            <span class="inline-block px-3 py-1 bg-red-600 text-white text-xs font-black uppercase tracking-widest rounded">Persönlich</span>
            <div class="mt-6 w-14 h-14 rounded-xl bg-red-600 flex items-center justify-center">
              <Icon name="phone" size={28}/>
            </div>
            <h2 class="mt-6 text-2xl font-black text-white">Telefon</h2>
            <p class="mt-3 text-white text-lg font-bold">+49 15566 111551</p>
            <p class="mt-2 text-gray-300 text-sm">Persönliche Beratung während Öffnungszeiten.</p>
            <div class="mt-6 inline-flex items-center gap-2 font-bold uppercase tracking-wide text-sm text-red-500 group-hover:gap-3 transition-all">
              Jetzt anrufen <Icon name="arrow" size={16}/>
            </div>
          </div>
        </a>

        <a href="mailto:info@ba-autoteile.de"
           class="group relative overflow-hidden rounded-2xl bg-white border border-gray-300 p-8 shadow-md hover:shadow-xl transition-all hover:-translate-y-1 hover:border-black">
          <div class="absolute -right-12 -top-12 w-48 h-48 rounded-full bg-gray-100 blur-2xl"></div>
          <div class="relative">
            <span class="inline-block px-3 py-1 bg-black text-white text-xs font-black uppercase tracking-widest rounded">Asynchron</span>
            <div class="mt-6 w-14 h-14 rounded-xl bg-black text-white flex items-center justify-center">
              <Icon name="mail" size={28}/>
            </div>
            <h2 class="mt-6 text-2xl font-black">E-Mail</h2>
            <p class="mt-3 text-lg font-bold">info@ba-autoteile.de</p>
            <p class="mt-2 text-gray-700 text-sm">Für alles, was nicht eilig ist. Antwort am gleichen Tag.</p>
            <div class="mt-6 inline-flex items-center gap-2 font-bold uppercase tracking-wide text-sm text-black group-hover:gap-3 transition-all">
              E-Mail schreiben <Icon name="arrow" size={16}/>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <section class="section gray-section">
    <div class="container-x">
      <div class="grid lg:grid-cols-2 gap-10">
        <div>
          <span class="eyebrow">Standort</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-black">Bleichmärsch 24<br/><span class="red-accent">Dortmund-Mitte.</span></h2>
          <span class="divider-red mt-5"></span>

          <div class="mt-10 space-y-6">
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-black text-white flex items-center justify-center flex-shrink-0">
                <Icon name="pin" size={24}/>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest font-bold text-gray-600">Anschrift</div>
                <div class="text-lg font-bold mt-1">
                  B&amp;A Autoteile<br/>
                  Bleichmärsch 24<br/>
                  44145 Dortmund-Mitte
                </div>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-black text-white flex items-center justify-center flex-shrink-0">
                <Icon name="clock" size={24}/>
              </div>
              <div class="flex-1">
                <div class="text-xs uppercase tracking-widest font-bold text-gray-600">Öffnungszeiten</div>
                <div class="mt-2 space-y-1 max-w-sm">
                  <div class="flex justify-between"><span class="font-bold">Mo - Fr</span><span>09:00 - 17:30</span></div>
                  <div class="flex justify-between"><span class="font-bold">Samstag</span><span class="red-accent font-bold">09:00 - 14:00</span></div>
                  <div class="flex justify-between"><span class="font-bold">Sonntag</span><span class="text-gray-600">geschlossen</span></div>
                </div>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-lg bg-black text-white flex items-center justify-center flex-shrink-0">
                <Icon name="euro" size={24}/>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest font-bold text-gray-600">Zahlung</div>
                <div class="mt-1 text-gray-800">Bar · EC-Karte · Überweisung · PayPal</div>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-xl border border-gray-300 aspect-square lg:aspect-auto lg:min-h-[500px]">
          <iframe
            src="https://maps.google.com/maps?q=Bleichm%C3%A4rsch%2024%2C%2044145%20Dortmund&t=&z=15&ie=UTF8&iwloc=&output=embed"
            width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="B&A Autoteile auf Google Maps"></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="black-section py-16 md:py-20">
    <div class="container-x text-center">
      <h2 class="text-3xl md:text-5xl font-black text-white">Komm vorbei oder<br/><span class="red-accent">schreib uns auf WhatsApp.</span></h2>
      <p class="mt-5 text-gray-300 max-w-xl mx-auto">Antwort meist unter 30 Min während Öffnungszeiten.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
          <Icon name="whatsapp" size={18}/> WhatsApp starten
        </a>
        <a href="tel:+4915566111551" class="btn btn-red btn-lg">
          <Icon name="phone" size={18}/> 0155 66 111551
        </a>
      </div>
    </div>
  </section>

</Layout>
