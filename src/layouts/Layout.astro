---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'B&A Autoteile Dortmund - Faire Preise, schneller Service',
  description = 'Autoteile Dortmund - WhatsApp-Foto schicken, Preis bekommen. Heute bestellt, morgen verbaut. 5.0★ aus 22 Bewertungen. Alle Marken.',
  image = '/og-image.svg',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['AutoPartsStore', 'LocalBusiness'],
  name: 'B&A Autoteile',
  image: ogImage,
  '@id': 'https://ba-autoteile-dortmund.pages.dev',
  url: 'https://ba-autoteile-dortmund.pages.dev',
  telephone: '+4915566111551',
  email: 'info@ba-autoteile.de',
  priceRange: '$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bleichmärsch 24',
    addressLocality: 'Dortmund',
    postalCode: '44145',
    addressCountry: 'DE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 51.5207393,
    longitude: 7.4767325,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:30',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '14:00',
    },
  ],
  paymentAccepted: ['Cash', 'EC-Karte', 'Überweisung', 'PayPal'],
  areaServed: ['Dortmund', 'Bochum', 'Castrop-Rauxel', 'Lünen', 'Nordrhein-Westfalen'],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '22',
  },
  sameAs: ['https://www.google.com/maps/place/?q=place_id:ChIJl888D80XuUcRhaL3pIVH1Y8'],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="B&A Autoteile Dortmund" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0A0A0A" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:rounded">Zum Inhalt</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
