---
import Icon from './Icon.astro';
const year = new Date().getFullYear();
const wa = 'https://wa.me/4915566111551?text=Hallo%2C%20ich%20suche%20folgendes%20Teil%3A%20';
---

<footer class="black-section">
  <div class="container-x py-16">
    <div class="grid md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-center gap-2 font-black tracking-tight text-2xl text-white">
          <span class="inline-flex items-center justify-center w-10 h-10 rounded-md bg-red-600 text-white font-black">B<span style="color:#fff">&amp;</span>A</span>
          <span>Autoteile</span>
        </a>
        <p class="mt-4 text-gray-300 max-w-md">
          Dein fairer Teile-Händler in Dortmund-Mitte. Heute bestellt - morgen verbaut. Faire Preise, ehrliche Beratung, alle Marken.
        </p>
        <div class="badge-rating mt-5">
          <span class="star">★★★★★</span>
          <span>5.0 aus 22 Bewertungen</span>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-black uppercase tracking-widest mb-4 text-red-500">Kontakt</h4>
        <ul class="space-y-3 text-gray-300">
          <li><a href="tel:+4915566111551" class="inline-flex items-center gap-2 hover:text-white"><Icon name="phone" size={16} class="red-accent"/> +49 15566 111551</a></li>
          <li><a href={wa} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-white"><Icon name="whatsapp" size={16} class="red-accent"/> WhatsApp</a></li>
          <li><a href="mailto:info@ba-autoteile.de" class="inline-flex items-center gap-2 hover:text-white"><Icon name="mail" size={16} class="red-accent"/> info@ba-autoteile.de</a></li>
          <li class="flex items-start gap-2 pt-2"><Icon name="pin" size={16} class="red-accent flex-shrink-0 mt-0.5"/> <span>Bleichmärsch 24<br/>44145 Dortmund-Mitte</span></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-black uppercase tracking-widest mb-4 text-red-500">Öffnungszeiten</h4>
        <ul class="space-y-2 text-gray-300">
          <li>Mo - Fr: 09:00 - 17:30</li>
          <li>Sa: 09:00 - 14:00</li>
          <li>So: geschlossen</li>
        </ul>
        <h4 class="text-sm font-black uppercase tracking-widest mt-6 mb-3 text-red-500">Navigation</h4>
        <ul class="space-y-1 text-gray-300 text-sm">
          <li><a href="/sortiment" class="hover:text-white">Sortiment</a></li>
          <li><a href="/marken" class="hover:text-white">Marken</a></li>
          <li><a href="/anfrage" class="hover:text-white">Anfrage</a></li>
          <li><a href="/ueber-uns" class="hover:text-white">Über uns</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between gap-4 text-sm text-gray-400">
      <p>© {year} B&amp;A Autoteile - Alle Rechte vorbehalten</p>
      <div class="flex gap-6">
        <a href="/impressum" class="hover:text-white">Impressum</a>
        <a href="/datenschutz" class="hover:text-white">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>

<a href={wa} target="_blank" rel="noopener" aria-label="WhatsApp"
   class="md:hidden fixed bottom-5 left-5 z-40 w-14 h-14 rounded-full bg-[#25D366] text-white shadow-xl flex items-center justify-center pulse-green">
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.711.307 1.265.489 1.697.626.713.227 1.362.195 1.875.118.572-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/></svg>
</a>

<a href="tel:+4915566111551" aria-label="Anrufen"
   class="md:hidden fixed bottom-5 right-5 z-40 w-14 h-14 rounded-full bg-red-600 text-white shadow-xl flex items-center justify-center pulse-red">
  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 0 0-1.02.24l-2.2 2.2a15.07 15.07 0 0 1-6.59-6.59l2.2-2.21a1 1 0 0 0 .25-1A11.36 11.36 0 0 1 8.5 4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1 17 17 0 0 0 17 17 1 1 0 0 0 1-1v-3.5a1 1 0 0 0-1-1z"/></svg>
</a>
