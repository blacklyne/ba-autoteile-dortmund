---
const nav = [
  { href: '/sortiment', label: 'Sortiment' },
  { href: '/marken', label: 'Marken' },
  { href: '/anfrage', label: 'Anfrage' },
  { href: '/ueber-uns', label: 'Über uns' },
  { href: '/kontakt', label: 'Kontakt' },
];
const wa = 'https://wa.me/4915566111551?text=Hallo%2C%20ich%20suche%20folgendes%20Teil%3A%20';
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="container-x flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2 font-black tracking-tight text-xl md:text-2xl">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-md bg-black text-white font-black">B<span style="color:#DC2626">&amp;</span>A</span>
      <span class="hidden sm:inline">Autoteile</span>
    </a>

    <nav class="hidden lg:flex items-center gap-7">
      {nav.map((n) => (
        <a href={n.href} class="text-sm font-bold uppercase tracking-wide text-gray-900 hover:text-red-600 transition">{n.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href={wa} target="_blank" rel="noopener" class="btn btn-whatsapp hidden md:inline-flex">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.711.307 1.265.489 1.697.626.713.227 1.362.195 1.875.118.572-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/></svg>
        <span>WhatsApp</span>
      </a>
      <a href="tel:+4915566111551" class="btn btn-red hidden sm:inline-flex">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 0 0-1.02.24l-2.2 2.2a15.07 15.07 0 0 1-6.59-6.59l2.2-2.21a1 1 0 0 0 .25-1A11.36 11.36 0 0 1 8.5 4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1 17 17 0 0 0 17 17 1 1 0 0 0 1-1v-3.5a1 1 0 0 0-1-1z"/></svg>
        <span class="hidden md:inline">Anrufen</span>
      </a>
      <a href="/anfrage" class="btn btn-outline hidden xl:inline-flex">Anfrage</a>

      <button id="mobile-menu-btn" aria-label="Menü" class="lg:hidden p-2 -mr-2">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-200 bg-white">
    <nav class="container-x flex flex-col py-4">
      {nav.map((n) => (
        <a href={n.href} class="py-3 text-base font-bold uppercase tracking-wide border-b border-gray-100 last:border-0">{n.label}</a>
      ))}
      <div class="flex gap-2 mt-4">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-whatsapp flex-1">WhatsApp</a>
        <a href="tel:+4915566111551" class="btn btn-red flex-1">Anrufen</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
